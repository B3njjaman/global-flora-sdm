# ---- Datos pesados descargados / derivados (no versionar) ----
data/raw/worldclim_present/*
data/raw/worldclim_future/*
data/processed/rasters_aligned/*
data/processed/species_datasets/*
data/processed/Especies_sudamerica.csv
data/modeling/ensemble_models/*
data/raw/natural_earth/
!**/.gitkeep

# Rasters y formatos pesados
*.tif
*.tiff
*.nc
*.grib
*.zip
*.7z

# Salidas regenerables
outputs/maps/*
outputs/figures/*
!outputs/**/.gitkeep
# Figuras canónicas V4 (mapas de idoneidad + panel): SÍ se versionan para revisión.
!outputs/figures/*_idoneidad_sa.png
!outputs/figures/_panel_idoneidad_v4.png
# Rasters de idoneidad para QGIS (21 especies): SÍ se versionan para abrirlos
# directamente desde el repo. Excepción a la regla global *.tif de arriba.
!outputs/raster_idoneidad/
!outputs/raster_idoneidad/*.tif
# Se conservan tablas de métricas (CSV) por ser ligeras y revisables

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.ipynb_checkpoints/
.pytest_cache/

# Entornos y secretos
.env
.cdsapirc

# IDE / SO
.vscode/
.idea/
.DS_Store
Thumbs.db
# Archivos lock temporales de Excel/Office
~$*

# Exports pesados regenerables y logs de proceso
outputs/tables/base_de_datos_completa.*
outputs/_*.txt

# Carpeta de ensamblaje del paquete (redundante con el zip)
entrega_jefe/
entrega CSA/
